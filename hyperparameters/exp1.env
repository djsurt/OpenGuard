import os, torch

# ── Swap this to any causal LM you want to fine-tune ─────────
BASE_MODEL_ID = "Qwen/Qwen3-1.7B"
# Examples:
#   "Qwen/Qwen3-4B", "Qwen/Qwen3-8B"
#   "meta-llama/Llama-3.2-3B-Instruct"
#   "Qwen/Qwen2.5-7B-Instruct"
#   "google/gemma-2-2b-it"
#   "mistralai/Mistral-7B-Instruct-v0.3"

# ── Training hyper-parameters (from paper Table 15 / 16) ─────
SFT_LR            = 3e-5      # Learning rate for SFT (tune per model size)
SFT_BATCH_SIZE     = 128       # Global batch size for SFT
SFT_GRAD_ACCUM     = 8         # Gradient accumulation steps
SFT_EPOCHS         = 1         # Paper trains for 1 epoch
SFT_MAX_SEQ_LEN    = 4096      # Max sequence length

GRPO_LR            = 3e-6      # Learning rate for GRPO
GRPO_BATCH_SIZE    = 64        # Global batch size for GRPO
GRPO_GRAD_ACCUM    = 4
GRPO_EPOCHS        = 1
GRPO_NUM_ROLLOUTS  = 12        # Number of rollouts per prompt
GRPO_MAX_NEW_TOKENS = 1024     # Max generation length during GRPO
GRPO_KL_COEFF      = 1e-3      # KL penalty coefficient
GRPO_NUM_SAMPLES   = 11_000    # Paper uses 11k samples for GRPO

# ── LoRA config (set USE_LORA=False for full fine-tune) ──────
USE_LORA           = True
LORA_R             = 64
LORA_ALPHA         = 128
LORA_DROPOUT       = 0.05

# ── Quantization (set to False if you have enough VRAM) ──────
USE_4BIT           = True